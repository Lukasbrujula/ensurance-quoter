# ============================================
# Ensurance Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# Required vars are marked [REQUIRED], optional ones [OPTIONAL]

# --- Clerk (Auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...        # [REQUIRED] Clerk publishable key
CLERK_SECRET_KEY=sk_test_...                          # [REQUIRED] Clerk secret key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login             # [REQUIRED] Sign-in page route
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/register          # [REQUIRED] Sign-up page route
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/quote  # [OPTIONAL] Post-login redirect
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/quote  # [OPTIONAL] Post-signup redirect
CLERK_WEBHOOK_SECRET=whsec_...                        # [REQUIRED] Svix webhook signing secret

# --- Supabase (Database) ---
NEXT_PUBLIC_SUPABASE_URL=https://orrppddoiumpwdqbavip.supabase.co  # [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                  # [REQUIRED] Anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...                      # [REQUIRED] Service role key (server-only, never expose)

# --- OpenAI ---
OPENAI_API_KEY=sk-...                                 # [REQUIRED] GPT-4o-mini for chat, coaching, extraction

# --- Compulife (Pricing API) ---
# Use EITHER direct auth OR proxy — not both
COMPULIFE_AUTH_ID=                                     # [CONDITIONAL] Direct Compulife auth (IP-locked)
COMPULIFE_PROXY_URL=                                   # [CONDITIONAL] DigitalOcean proxy URL
COMPULIFE_PROXY_SECRET=                                # [REQUIRED with PROXY_URL] Proxy auth secret

# --- Telnyx (Voice, SMS, AI Agents) ---
TELNYX_API_KEY=KEY...                                 # [REQUIRED] Telnyx API v2 key
TELNYX_WEBHOOK_PUBLIC_KEY=                             # [REQUIRED] ED25519 public key for webhook verification
TELNYX_CONNECTION_ID=                                  # [REQUIRED] SIP connection for WebRTC
TELNYX_CALLER_NUMBER=+1...                            # [OPTIONAL] Fallback caller ID for SMS
TELNYX_WEBHOOK_BASE_URL=                               # [OPTIONAL] Override webhook base URL

# --- Deepgram (Transcription) ---
DEEPGRAM_API_KEY=                                     # [REQUIRED] Deepgram API key

# --- People Data Labs (Enrichment) ---
PEOPLEDATALABS_API_KEY=                               # [REQUIRED] PDL API key

# --- Google (Calendar Integration) ---
GOOGLE_CLIENT_ID=                                     # [OPTIONAL] Google OAuth client ID
GOOGLE_CLIENT_SECRET=                                 # [OPTIONAL] Google OAuth client secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback  # [OPTIONAL]

# --- Resend (Email) ---
RESEND_API_KEY=re_...                                 # [OPTIONAL] Email disabled if absent
RESEND_FROM=noreply@yourdomain.com                    # [OPTIONAL] From address

# --- Upstash Redis (Rate Limiting) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io          # [OPTIONAL] Rate limiting fails open if absent
UPSTASH_REDIS_REST_TOKEN=                              # [OPTIONAL]

# --- Security & Internal ---
ENCRYPTION_SECRET=                                     # [REQUIRED] AES-256-GCM key (generate: openssl rand -base64 32)
INTERNAL_API_SECRET=                                   # [REQUIRED] Server-to-server auth
NEXT_PUBLIC_APP_URL=http://localhost:3000              # [REQUIRED] CSRF validation + webhook URLs
CRON_SECRET=                                           # [REQUIRED] Vercel cron job auth
