# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env*.local
.env.test
.env.staging
.env.production

# vercel
.vercel

# claude code (contains MCP tokens)
.claude/mcp.json
.mcp.json

# typescript
*.tsbuildinfo
next-env.d.ts

# reference repos (cloned for study, not committed)
docs/references/
# Compulife server env (but keep .env.example)
Compulife/server/.env
Compulife/server/node_modules/

# Compulife API test output (contains auth ID)
compulife-response-raw.json
